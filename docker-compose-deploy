version: '3.8'

services:
  portafolio:
    image: nginx:latest
    container_name: cicata-frontend
    restart: always
    ports:
      - "85:80"
    volumes:
      - "./build:/usr/share/nginx/html"
      - "./nginx-config/default.conf:/etc/nginx/conf.d/default.conf"
    networks:
      - nginxreverse_default
      - cicataNetwork  # allows it to talk to backend if needed (optional)

  cloudFlareDC3WebBeta:
    image: cloudflare/cloudflared
    restart: always
    command: tunnel --no-autoupdate run --token eyJhIjoiYjk5NjBhZGY5OGQzOWUzZGY5OTc3MWQ4YTk3YTBmMmEiLCJ0IjoiMTBkNjU1NzAtMjNlMy00YmIyLWE2OWMtZGVlMDlmYThkNzI3IiwicyI6IlptWXlOMkpsTlRndFlqWTBPUzAwWldSbExUbG1Zamt0WWpjM1lqTTRZekF5Wm1JMCJ9
    networks:
      - nginxreverse_default

networks:
  nginxreverse_default:
    external: true
    name: nginxreverse_default

  cicataNetwork:
    external: true
    name: cicataNetwork